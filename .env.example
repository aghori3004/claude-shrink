# Primary provider: openrouter (recommended) or cloudflare
PROVIDER=openrouter

# --- OpenRouter (recommended) ---
# Free key at openrouter.ai/keys — no credit card required
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Cloudflare Workers AI (alternative, free tier has daily cap) ---
CF_ACCOUNT_ID=your_account_id_here
CF_API_TOKEN=your_api_token_here
