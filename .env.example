# Provider is auto-detected from which credentials are present.
# If OPENROUTER_API_KEY is set, OpenRouter is used (preferred).
# If only CF_ACCOUNT_ID + CF_API_TOKEN are set, Cloudflare is used.
# If both are set, OpenRouter takes priority.
# If neither is set, the server will fail with a clear error at startup.

# --- OpenRouter (default) ---
# Sign up at openrouter.ai/keys, then add credits at openrouter.ai/credits.
# Kimi K2.6 is a paid model (~$0.01-0.02 per call).
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Cloudflare Workers AI (free alternative, 10K neurons/day cap) ---
# CF_ACCOUNT_ID=your_account_id_here
# CF_API_TOKEN=your_api_token_here
